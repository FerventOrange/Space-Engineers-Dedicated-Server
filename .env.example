# Required: Steam credentials for SteamCMD
STEAM_USER=
STEAM_PASS=

# Server settings
SERVER_NAME=Space Engineers Server
WORLD_NAME=Star System
SERVER_PORT=27016

# Admin Steam64 IDs (comma-separated)
ADMIN_IDS=

# Workshop mod IDs (comma-separated)
MODS=

# Backup configuration
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=7
MAX_BACKUP_SAVES=5

# Paths (inside container) — override to use custom mount points
WORLD_DIR=/server/world
BACKUP_DIR=/server/backups

# Auto-update server on container start
AUTO_UPDATE=true
