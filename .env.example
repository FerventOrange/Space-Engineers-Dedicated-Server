# Required: Steam credentials for SteamCMD
STEAM_USER=
STEAM_PASS=

# Server settings
SERVER_NAME=Space Engineers Server
WORLD_NAME=Star System
SERVER_PORT=27016

# Admin Steam64 IDs (comma-separated)
ADMIN_IDS=

# Workshop mod IDs (comma-separated)
MODS=

# Backup configuration
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=7
MAX_BACKUP_SAVES=28

# Game multipliers (applied on initial world creation)
INVENTORY_SIZE_MULTIPLIER=10
BLOCKS_INVENTORY_SIZE_MULTIPLIER=10
ASSEMBLER_SPEED_MULTIPLIER=10
ASSEMBLER_EFFICIENCY_MULTIPLIER=10
REFINERY_SPEED_MULTIPLIER=10
WELDER_SPEED_MULTIPLIER=5
GRINDER_SPEED_MULTIPLIER=5
HARVEST_RATIO_MULTIPLIER=5

# Paths (inside container) — override to use custom mount points
WORLD_DIR=/server/world
BACKUP_DIR=/server/backups

# Auto-update server on container start
AUTO_UPDATE=true
